{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/ericwooley/worktreeman/main/worktree.schema.json",
  "title": "worktreeman Config",
  "description": "Schema for worktree.yml / worktreeman.yml configuration files.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional editor hint for schema-aware YAML tooling. The comment header form is preferred."
    },
    "env": {
      "type": "object",
      "description": "Static environment variables injected into every runtime.",
      "default": {},
      "additionalProperties": {
        "type": "string"
      }
    },
    "runtimePorts": {
      "type": "array",
      "description": "Environment variable names that should receive allocated free local ports.",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "derivedEnv": {
      "type": "object",
      "description": "Environment variables rendered from other env and configured runtime port values.",
      "default": {},
      "additionalProperties": {
        "type": "string"
      }
    },
    "quickLinks": {
      "type": "array",
      "description": "UI links rendered after runtime env and derived env are assembled.",
      "default": [],
      "items": {
        "$ref": "#/$defs/quickLinkEntry"
      }
    },
    "startupCommands": {
      "type": "array",
      "description": "Commands run inside the worktree after the environment starts.",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "backgroundCommands": {
      "type": "object",
      "description": "Named long-running commands shown in the Background commands tab.",
      "default": {},
      "additionalProperties": {
        "$ref": "#/$defs/backgroundCommandEntry"
      }
    },
    "worktrees": {
      "$ref": "#/$defs/worktreesConfig"
    }
  },
  "$defs": {
    "backgroundCommandEntry": {
      "description": "A named background command. A bare string is shorthand for { command: <string> }.",
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "command"
          ],
          "properties": {
            "command": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "quickLinkEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "url"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "worktreesConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseDir": {
          "type": "string",
          "description": "Directory where git worktrees are created.",
          "default": ".worktrees"
        }
      },
      "required": [
        "baseDir"
      ]
    }
  }
}
