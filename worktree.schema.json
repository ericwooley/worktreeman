{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/ericwooley/worktreeman/main/worktree.schema.json",
  "title": "worktreeman Config",
  "description": "Schema for worktree.yml / worktreeman.yml configuration files.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional editor hint for schema-aware YAML tooling. The comment header form is preferred."
    },
    "env": {
      "type": "object",
      "description": "Static environment variables injected into every runtime.",
      "default": {},
      "additionalProperties": {
        "type": "string"
      }
    },
    "favicon": {
      "type": "string",
      "description": "Repository-relative path to an image file served as the UI favicon.",
      "default": ""
    },
    "preferredPort": {
      "type": "integer",
      "description": "Preferred local port for the worktreeman web server. If unavailable, worktreeman falls back to a free port.",
      "minimum": 1
    },
    "runtimePorts": {
      "type": "array",
      "description": "Environment variable names that should receive allocated free local ports.",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "derivedEnv": {
      "type": "object",
      "description": "Environment variables rendered from other env and configured runtime port values.",
      "default": {},
      "additionalProperties": {
        "type": "string"
      }
    },
    "quickLinks": {
      "type": "array",
      "description": "UI links rendered after runtime env and derived env are assembled.",
      "default": [],
      "items": {
        "$ref": "#/$defs/quickLinkEntry"
      }
    },
    "autoSync": {
      "$ref": "#/$defs/autoSyncConfig"
    },
    "aiCommands": {
      "$ref": "#/$defs/aiCommandConfig"
    },
    "startupCommands": {
      "type": "array",
      "description": "Commands run inside the worktree after the environment starts.",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "backgroundCommands": {
      "type": "object",
      "description": "Named long-running commands shown in the Background commands tab.",
      "default": {},
      "additionalProperties": {
        "$ref": "#/$defs/backgroundCommandEntry"
      }
    },
    "projectManagement": {
      "$ref": "#/$defs/projectManagementConfig"
    },
    "worktrees": {
      "$ref": "#/$defs/worktreesConfig"
    }
  },
  "$defs": {
    "backgroundCommandEntry": {
      "description": "A named background command. A bare string is shorthand for { command: <string> }.",
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "command"
          ],
          "properties": {
            "command": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "aiCommandConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "smart": {
          "type": "string",
          "description": "Higher-context AI command template run inside a selected worktree. Include $WTM_AI_INPUT where the generated prompt should be inserted.",
          "default": ""
        },
        "simple": {
          "type": "string",
          "description": "Faster or lighter-weight AI command template run inside a selected worktree. Include $WTM_AI_INPUT where the generated prompt should be inserted.",
          "default": ""
        },
        "autoStartRuntime": {
          "type": "boolean",
          "description": "Automatically start a worktree runtime before running an AI command when one is not already active.",
          "default": false
        }
      },
      "default": {
        "smart": "",
        "simple": "",
        "autoStartRuntime": false
      }
    },
    "autoSyncConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "remote": {
          "type": "string",
          "description": "Remote name used for document auto sync pull and push operations.",
          "default": "origin",
          "minLength": 1
        }
      },
      "default": {
        "remote": "origin"
      }
    },
    "quickLinkEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "url"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "worktreesConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseDir": {
          "type": "string",
          "description": "Directory where git worktrees are created.",
          "default": ".worktrees"
        }
      },
      "required": [
        "baseDir"
      ]
    },
    "projectManagementConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "users": {
          "$ref": "#/$defs/projectManagementUsersConfig"
        }
      }
    },
    "projectManagementUsersConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "customUsers": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/projectManagementUserConfigEntry"
          }
        },
        "archivedUserIds": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "projectManagementUserConfigEntry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      }
    }
  }
}
