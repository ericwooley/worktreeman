{
  "name": "worktreemanager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "worktreemanager": "dist/cli.js"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/cli.ts",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.node.json",
    "build:web": "vite build",
    "start": "node dist/cli.js",
    "check": "tsc -p tsconfig.node.json --noEmit && vite build --mode production"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "node-pty": "^1.0.0",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  }
}
