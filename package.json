{
  "name": "worktreeman",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "esbuild",
    "node-pty"
  ],
  "files": [
    "dist/cli.js",
    "dist/server",
    "dist/shared",
    "dist/web",
    "README.md",
    "worktree.schema.json"
  ],
  "bin": {
    "worktreeman": "dist/cli.js"
  },
  "scripts": {
    "clean:server-dist": "node --input-type=module -e \"import fs from 'node:fs'; for (const target of ['dist/cli.js', 'dist/server', 'dist/shared']) fs.rmSync(target, { recursive: true, force: true });\"",
    "clean:web-dist": "node --input-type=module -e \"import fs from 'node:fs'; fs.rmSync('dist/web', { recursive: true, force: true });\"",
    "dev": "NODE_ENV=development tsx src/cli.ts",
    "dev:watch": "NODE_ENV=development tsx watch src/cli.ts start",
    "test": "bash -O globstar -c 'tsx --test src/**/*.test.ts src/**/*.test.tsx'",
    "check:web": "vite build --mode production",
    "check:docs": "vite build --config vite.docs.config.ts --mode production",
    "check:server": "tsc -p tsconfig.node.json --noEmit",
    "build": "bun run build:server && bun run build:web && bun run build:docs",
    "build:server": "bun run clean:server-dist && tsc -p tsconfig.node.json",
    "build:web": "bun run clean:web-dist && vite build",
    "build:docs": "vite build --config vite.docs.config.ts",
    "preview:docs": "bun run build:docs && http-server dist/docs -p 4174 -c-1",
    "prepack": "bun run build:server && bun run build:web",
    "start": "node dist/cli.js",
    "check": "bun run test && bun run check:server && bun run check:web && bun run check:docs"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.4",
    "@electric-sql/pglite": "^0.4.1",
    "@git-diff-view/core": "^0.1.2",
    "@git-diff-view/react": "^0.1.2",
    "@gitgraph/react": "^1.6.0",
    "@inquirer/prompts": "^8.3.2",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.10.1",
    "cmd-ts": "^0.14.1",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.12",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "open": "^10.1.0",
    "pg-boss": "^12.14.0",
    "pm2": "^6.0.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "http-server": "^14.1.1",
    "postcss": "^8.5.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  }
}
