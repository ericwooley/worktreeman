{
  "name": "worktreeman",
  "version": "0.2.3",
  "type": "module",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "repository":"https://github.com/ericwooley/worktreeman",
  "imports": {
    "#test-runtime": "./src/shared/test-runtime.ts"
  },
  "files": [
    "dist/cli.js",
    "dist/server",
    "dist/shared",
    "dist/web",
    "README.md",
    "worktree.schema.json"
  ],
  "bin": {
    "worktreeman": "dist/cli.js"
  },
  "scripts": {
    "clean:server-dist": "node --input-type=module -e \"import fs from 'node:fs'; for (const target of ['dist/cli.js', 'dist/server', 'dist/shared']) fs.rmSync(target, { recursive: true, force: true });\"",
    "clean:web-dist": "node --input-type=module -e \"import fs from 'node:fs'; fs.rmSync('dist/web', { recursive: true, force: true });\"",
    "dev": "NODE_ENV=development ./node_modules/.bin/tsx src/cli.ts",
    "dev:watch": "NODE_ENV=development node --import tsx src/server/entrypoints/dev-entrypoint.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:web": "vite build --mode production",
    "check:docs": "vite build --config vite.docs.config.ts --mode production",
    "check:server": "tsc -p tsconfig.node.json --noEmit",
    "build": "pnpm run build:server && pnpm run build:web && pnpm run build:docs",
    "build:server": "pnpm run clean:server-dist && tsc -p tsconfig.node.build.json",
    "build:web": "pnpm run clean:web-dist && vite build",
    "build:docs": "vite build --config vite.docs.config.ts",
    "preview:docs": "pnpm run build:docs && http-server dist/docs -p 4174 -c-1",
    "prepack": "pnpm run build:server && pnpm run build:web",
    "start": "node dist/cli.js",
    "check": "pnpm run test && pnpm run check:server && pnpm run check:web && pnpm run check:docs"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.4",
    "@electric-sql/pglite": "^0.4.1",
    "@electric-sql/pglite-socket": "^0.1.2",
    "@git-diff-view/core": "^0.1.2",
    "@git-diff-view/react": "^0.1.2",
    "@gitgraph/react": "^1.6.0",
    "@inquirer/prompts": "^8.3.2",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.10.1",
    "cmd-ts": "^0.14.1",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.12",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "open": "^10.1.0",
    "pg": "^8.20.0",
    "pg-boss": "^12.14.0",
    "pm2": "^6.0.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "http-server": "^14.1.1",
    "postcss": "^8.5.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
